{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Study Note",
  "type": "object",
  "required": [
    "title",
    "timestamp_utc",
    "track",
    "query",
    "atomic_notes",
    "flashcards",
    "next_actions"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "track": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "atomic_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "flashcards": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
