{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Note",
  "type": "object",
  "required": [
    "title",
    "timestamp_utc",
    "query",
    "approach",
    "deliverables"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "approach": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
