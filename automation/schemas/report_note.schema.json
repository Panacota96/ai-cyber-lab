{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report Note",
  "type": "object",
  "required": [
    "title",
    "timestamp_utc",
    "query",
    "session_id",
    "log_lines_used",
    "evidence_items",
    "output"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "log_lines_used": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_items": {
      "type": "integer",
      "minimum": 0
    },
    "output": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
